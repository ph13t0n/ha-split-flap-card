.pnp.*
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

# Vite log files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Local Home Assistant development copies
.local-ha/
home-assistant-config/
config/www/ha-split-flap-card.js

